<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Lock Icon -->
            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                android:layout_marginTop="40dp"
                app:tint="@color/accent" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"
                android:shadowColor="@color/accent"
                android:shadowRadius="15"
                android:layout_marginBottom="8dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update your account password"
                android:textColor="@color/accent"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="40dp" />

            <!-- Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Current Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Password"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/accent"
                        app:boxBackgroundMode="none"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/currentPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_edittext_light"
                            android:hint="Enter current password"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingStart="20dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/accent" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- New Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Password"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/accent"
                        app:boxBackgroundMode="none"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/newPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_edittext_light"
                            android:hint="Enter new password"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingStart="20dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/accent" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confirm New Password"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/accent"
                        app:boxBackgroundMode="none"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/confirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_edittext_light"
                            android:hint="Confirm new password"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_primary"
                            android:paddingStart="20dp"
                            android:paddingEnd="48dp"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawablePadding="12dp"
                            android:drawableTint="@color/accent" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Hint text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password must be at least 6 characters"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="24dp" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="@color/accent"
                        android:layout_marginBottom="16dp" />

                    <!-- Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/cancelButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="Cancel"
                            android:textColor="@color/accent"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_outline_bg"
                            android:stateListAnimator="@null" />

                        <Button
                            android:id="@+id/changePasswordButton"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Change Password"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_scan_bg"
                            android:stateListAnimator="@null" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>