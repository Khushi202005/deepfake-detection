<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Glassmorphic Header -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="0dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Logo and Buttons Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Logo -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <ImageView
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:src="@drawable/ic_shield"
                                    android:alpha="0.3"
                                    app:tint="@color/accent" />

                                <ImageView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_shield"
                                    app:tint="@color/accent" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="@string/app_name"
                                android:textColor="@color/accent"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"
                                android:singleLine="true"
                                android:maxLines="1"
                                android:ellipsize="none"
                                android:shadowColor="@color/accent"
                                android:shadowRadius="10" />
                        </LinearLayout>

                        <!-- Login Button -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnLogin"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/login"
                            android:textColor="@color/accent"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_outline_bg"
                            android:layout_marginEnd="8dp"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:minWidth="90dp" />

                        <!-- Signup Button -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnSignup"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/signup"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            android:background="@drawable/btn_primary_bg"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:minWidth="90dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hero Section -->
            <LinearLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protect Yourself from\nDeepfakes"
                    android:textColor="@color/text_primary"
                    android:textSize="34sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:shadowColor="@color/accent"
                    android:shadowRadius="20"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload videos, images, or audio files to detect\nAI-generated deepfakes with cutting-edge technology."
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:layout_marginBottom="28dp" />

                <!-- Start Button with glow -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnStartScanning"
                        android:layout_width="210dp"
                        android:layout_height="60dp"
                        android:text="@string/start_scanning"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_primary_bg"
                        android:elevation="0dp"
                        android:stateListAnimator="@null" />
                </FrameLayout>
            </LinearLayout>

            <!-- Services Section -->
            <LinearLayout
                android:id="@+id/servicesSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Our Detection Services"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center"
                    android:shadowColor="@color/accent"
                    android:shadowRadius="10" />

                <!-- Image Scan Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardImageScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical">

                        <!-- Icon with glow -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp">

                            <ImageView
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:src="@drawable/ic_image"
                                android:alpha="0.3"
                                app:tint="@color/accent" />

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_image"
                                app:tint="@color/accent" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Image Scan"
                                android:textColor="@color/text_primary"
                                android:textSize="19sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detect manipulated images and AI-generated faces"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Video Scan Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardVideoScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp">

                            <ImageView
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:src="@drawable/ic_video"
                                android:alpha="0.3"
                                app:tint="@color/accent" />

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_video"
                                app:tint="@color/accent" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Video Scan"
                                android:textColor="@color/text_primary"
                                android:textSize="19sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analyze videos for deepfake manipulation"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Audio Scan Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAudioScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp">

                            <ImageView
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:src="@drawable/ic_audio"
                                android:alpha="0.3"
                                app:tint="@color/accent" />

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_audio"
                                app:tint="@color/accent" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Audio Scan"
                                android:textColor="@color/text_primary"
                                android:textSize="19sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detect AI-generated voice cloning"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- URL Scan Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUrlScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="24dp"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp">

                            <ImageView
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:src="@drawable/ic_url"
                                android:alpha="0.3"
                                app:tint="@color/accent" />

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_url"
                                app:tint="@color/accent" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="URL Scan"
                                android:textColor="@color/text_primary"
                                android:textSize="19sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan media from web URLs"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- About Us Section -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAboutUs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                app:cardBackgroundColor="@color/card_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:src="@drawable/ic_about"
                            android:alpha="0.3"
                            app:tint="@color/accent" />

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_about"
                            app:tint="@color/accent" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About Us"
                        android:textColor="@color/text_primary"
                        android:textSize="21sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Learn more about DeepGuard"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2025-26 DeepGuard. All rights reserved."
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:padding="24dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>